{
  tabs: {
    height: 'wrap',
    width: 'parent',
    top: ['parent', 'top', 8],
    start: ['parent', 'start', 8],
  },
  menu_btn: {
    width: 'wrap',
    height: 'wrap',
    top: ['tabs', 'top', 0],
    end: ['parent', 'end', 18],
    bottom: ['tabs', 'bottom', 0],
  },
  search_bar: {
    height: 'wrap',
    width: 'spread',
    end: ['parent', 'end', 18],
    top: ['tabs', 'bottom', 6],
    start: ['parent', 'start', 18]
  },
  pager: {
    width: 'spread',
    height: 'spread',
    translationZ: -1,
    end: ['parent', 'end', 6],
    start: ['parent', 'start', 6],
    top: ['search_bar', 'bottom', 6],
    bottom: ['parent', 'bottom', 0]
  }
}
